# Generated by Hermes Ultimate installer.
# Do not commit rendered secrets from ~/.hermes/gateway.yaml.

telegrams:
  - id: telegram
    name: Hermes Main Bot
    token: "{{ telegram_bot_token }}"
    default_soul: default
    allowed_users:
{% for user_id in telegram_allowed_users %}
      - "{{ user_id }}"
{% endfor %}
{% if with_second_bot %}
  - id: red
    name: Hermes Red Bot
    token: "{{ telegram_red_bot_token }}"
    default_soul: red
    allowed_users:
{% for user_id in telegram_red_allowed_users %}
      - "{{ user_id }}"
{% endfor %}
{% endif %}
